# YNAB OAuth application credentials.
# Create an OAuth application at https://app.ynab.com/settings/developer
# Copy this file to .env.local and fill in the values (never commit .env.local).

# From your YNAB OAuth application:
YNAB_CLIENT_ID=
YNAB_CLIENT_SECRET=

# Must byte-exactly match a Redirect URI registered on the OAuth application.
# Local dev:  http://localhost:3000/api/auth/callback
# Production: https://<your-project>.vercel.app/api/auth/callback
YNAB_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Encrypts the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Use a DIFFERENT value in production.
SESSION_SECRET=
COPILOT_KIT_SECRET=